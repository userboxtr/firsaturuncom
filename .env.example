# ═══════════════════════════════════════
# FIRSAT ÜRÜN - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp düzenleyin
# ═══════════════════════════════════════

# Sunucu portu
PORT=3000

# JWT Secret — Güçlü rastgele bir anahtar oluşturun:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=BURAYA_GUCLU_SECRET_YAZIN

# AI sağlayıcı API anahtarı (opsiyonel — admin panelinden de ayarlanabilir)
GEMINI_API_KEY=

# Ortam (development / production)
NODE_ENV=production

# İzin verilen origin'ler (virgülle ayır, boş bırakılırsa hepsi kabul edilir)
# Örnek: https://firsaturun.com,http://localhost:3000
ALLOWED_ORIGINS=
